# Generated campaign outputs
campaigns/*/audio/*
campaigns/**/audio/*
videos/renders/*
videos/revid-jobs/*

# Generated media and provider artifacts
*.mp3
*.mp4
*.wav
*.m4a
*.aac
*.mov
*.webm
*.srt
*.vtt
*.audio-url.txt
*.fileio-response.json
*.tmpfiles-response.json
