# Keep intended placeholder directories
!campaigns/*/audio/.gitkeep
!campaigns/**/audio/.gitkeep
!videos/renders/.gitkeep
!videos/thumbnails/.gitkeep
!videos/revid-jobs/.gitkeep

# Local/private drafts
drafts/

# Python and local tooling
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# OS/editor noise
.DS_Store
Thumbs.db
*.tmp
*.log
